{
  "name": "locker-os",
  "version": "1.0.0",
  "description": "LockerOS — Hệ thống quản lý tủ locker chung cư",
  "main": "src/index.js",
  "scripts": {
    "start":        "node src/index.js",
    "dev":          "nodemon src/index.js",
    "build":        "cd client && npm install && npm run build",
    "setup":        "npm install && npm run build",
    "dev:client":   "cd client && npm run dev"
  },
  "dependencies": {
    "bcryptjs":     "^2.4.3",
    "cors":         "^2.8.5",
    "dotenv":       "^16.4.5",
    "express":      "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "mysql2":       "^3.9.7",
    "nodemailer":   "^6.9.13",
    "socket.io":    "^4.7.5"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  }
}
